<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Italy & Istanbul — Aug 27 – Sep 7, 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1612;
  --ink2: #3d3530;
  --muted: #7a6f66;
  --muted2: #a89f96;
  --parchment: #f5f0e8;
  --parchment2: #ede6d8;
  --parchment3: #e4dace;
  --gold: #b8892a;
  --gold2: #d4a94a;
  --rome: #9c2f2f;
  --sicily: #b06414;
  --istanbul: #1a5c7a;
  --border: rgba(26,22,18,0.12);
  --border2: rgba(26,22,18,0.2);
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Jost', sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--parchment);color:var(--ink);font-family:var(--font-body);font-size:14px;font-weight:300;line-height:1.6;min-height:100vh}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.5}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(245,240,232,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);height:52px;display:flex;align-items:center;padding:0 32px;transition:box-shadow 0.3s}
#nav.scrolled{box-shadow:0 2px 20px rgba(26,22,18,0.1)}
.nav-logo{font-family:var(--font-display);font-size:18px;font-weight:300;color:var(--ink);margin-right:auto;letter-spacing:0.5px}
.nav-logo span{color:var(--gold)}
.nav-steps{display:flex;overflow-x:auto;scrollbar-width:none}
.nav-steps::-webkit-scrollbar{display:none}
.nav-step{padding:6px 12px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);cursor:pointer;white-space:nowrap;border-radius:4px;transition:all 0.15s}
.nav-step:hover{color:var(--ink);background:var(--parchment2)}
.nav-step.active{color:var(--gold)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 64px 80px;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 60% 30%,rgba(176,100,20,0.08) 0%,transparent 70%),radial-gradient(ellipse 60% 80% at 20% 70%,rgba(156,47,47,0.06) 0%,transparent 60%);z-index:0}
.hero-content{position:relative;z-index:1;max-width:760px}
.hero-eyebrow{font-family:var(--font-body);font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:20px;display:flex;align-items:center;gap:12px;animation:fadeUp 0.7s ease 0.2s both}
.hero-eyebrow::before{content:'';display:block;width:40px;height:1px;background:var(--gold)}
.hero-title{font-family:var(--font-display);font-size:clamp(56px,8vw,96px);font-weight:300;line-height:0.95;letter-spacing:-1px;color:var(--ink);margin-bottom:28px;animation:fadeUp 0.7s ease 0.4s both}
.hero-title em{font-style:italic;color:var(--gold)}
.hero-meta{display:flex;gap:32px;flex-wrap:wrap;margin-bottom:40px;animation:fadeUp 0.7s ease 0.6s both}
.meta-item{display:flex;flex-direction:column;gap:3px}
.meta-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted2)}
.meta-value{font-size:15px;font-weight:400}
.hero-flights{display:flex;flex-direction:column;gap:8px;animation:fadeUp 0.7s ease 0.8s both}
.flight-row{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.5);border:1px solid var(--border);border-radius:8px;padding:10px 16px;max-width:600px;backdrop-filter:blur(4px)}
.flight-cities{font-family:var(--font-display);font-size:17px;font-weight:400;letter-spacing:0.5px;min-width:120px}
.flight-divider{flex:1;display:flex;align-items:center;gap:8px}
.flight-divider::before,.flight-divider::after{content:'';flex:1;height:1px;background:var(--border2)}
.flight-plane{font-size:12px;color:var(--gold)}
.flight-info{font-size:11px;color:var(--muted);text-align:right}
.flight-date{font-size:11px;color:var(--muted2);min-width:44px}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* SECTIONS */
.section{max-width:900px;margin:0 auto;padding:80px 32px}
.section+.section{padding-top:0}

/* CITY BANNERS */
.city-banner{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;padding:40px 0 28px;border-bottom:1px solid var(--border2);margin-bottom:32px;position:relative}
.city-banner::before{content:'';position:absolute;bottom:-1px;left:0;width:80px;height:2px}
.city-banner.rome::before{background:var(--rome)}
.city-banner.sicily::before{background:var(--sicily)}
.city-ghost{position:absolute;right:0;bottom:0;font-family:var(--font-display);font-size:80px;font-weight:300;opacity:0.07;user-select:none;letter-spacing:-2px;line-height:1}
.city-title{font-family:var(--font-display);font-size:48px;font-weight:300;line-height:1;letter-spacing:-0.5px}
.city-title em{font-style:italic}
.city-tagline{font-size:13px;color:var(--muted);margin-top:8px;font-weight:300}
.city-nights-num{font-family:var(--font-display);font-size:36px;font-weight:300;line-height:1}
.city-nights-label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);display:block;margin-top:2px}

/* ISTANBUL PHOTO CARD */
.ist-photo-card{border-radius:14px;overflow:hidden;position:relative;margin-bottom:32px;aspect-ratio:16/7;background:#0e2a38}
.ist-photo-card svg{width:100%;height:100%;display:block;position:absolute;inset:0}
.ist-photo-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(14,42,56,0.75) 0%,rgba(14,42,56,0.1) 60%);display:flex;flex-direction:column;justify-content:flex-end;padding:28px 32px}
.ist-photo-label{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:6px}
.ist-photo-title{font-family:var(--font-display);font-size:36px;font-weight:300;color:#fff;line-height:1.1;text-shadow:0 2px 12px rgba(0,0,0,0.3)}
.ist-photo-title em{font-style:italic;color:#7ecfee}
.ist-photo-sub{font-size:12px;color:rgba(255,255,255,0.55);margin-top:6px}

/* DAY ACCORDION */
.day-item{border-bottom:1px solid var(--border);opacity:0;transform:translateY(16px);transition:opacity 0.5s ease,transform 0.5s ease}
.day-item.visible{opacity:1;transform:translateY(0)}
.day-trigger{display:flex;align-items:center;gap:20px;padding:20px 0;cursor:pointer;user-select:none}
.day-trigger:hover .day-trigger-title{color:var(--city-color,var(--gold))}
.day-num-badge{font-family:var(--font-display);font-size:13px;font-weight:500;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--border2);color:var(--muted);transition:all 0.2s}
.day-item.open .day-num-badge{border-color:var(--city-color,var(--gold));color:var(--city-color,var(--gold));background:rgba(184,137,42,0.08)}
.day-trigger-text{flex:1}
.day-trigger-date{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);margin-bottom:3px}
.day-trigger-title{font-family:var(--font-display);font-size:22px;font-weight:400;line-height:1.2;color:var(--ink);transition:color 0.2s}
.day-arrow{width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border);border-radius:50%;transition:all 0.3s;flex-shrink:0}
.day-item.open .day-arrow{transform:rotate(180deg);border-color:var(--city-color,var(--gold));background:rgba(184,137,42,0.08)}
.day-arrow svg{width:12px;height:12px;stroke:var(--muted);fill:none;transition:stroke 0.2s}
.day-item.open .day-arrow svg{stroke:var(--city-color,var(--gold))}
.day-body{display:grid;grid-template-rows:0fr;transition:grid-template-rows 0.35s ease}
.day-item.open .day-body{grid-template-rows:1fr}
.day-body-inner{overflow:hidden}
.day-slots{padding:0 0 28px 56px;display:flex;flex-direction:column}
.slot{display:grid;grid-template-columns:70px 1fr;gap:16px;padding:14px 0;border-left:1px solid var(--border);position:relative}
.slot::before{content:'';position:absolute;left:-4px;top:20px;width:7px;height:7px;border-radius:50%;background:var(--parchment);border:1px solid var(--border2)}
.slot:first-child::before{border-color:var(--city-color,var(--gold));background:var(--city-color,var(--gold))}
.slot-time{padding-left:16px;font-size:11px;letter-spacing:0.5px;color:var(--muted2);padding-top:2px;line-height:1.4}
.slot-name{font-size:14px;font-weight:400;color:var(--ink);margin-bottom:4px}
.slot-note{font-size:13px;color:var(--muted);line-height:1.55;font-weight:300}
.slot-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.tag{font-size:11px;padding:3px 10px;border-radius:20px;letter-spacing:0.3px;font-weight:400}
.tag-tip{background:rgba(184,137,42,0.1);color:var(--gold);border:1px solid rgba(184,137,42,0.25)}
.tag-food{background:rgba(60,130,80,0.08);color:#2d6b40;border:1px solid rgba(60,130,80,0.2)}

/* RETURN CARD */
.return-card{background:var(--ink);color:var(--parchment);border-radius:12px;padding:32px 36px;margin-top:48px;position:relative;overflow:hidden}
.return-card::before{content:'HOME';position:absolute;right:-10px;top:50%;transform:translateY(-50%);font-family:var(--font-display);font-size:80px;font-weight:300;opacity:0.05;letter-spacing:8px}
.return-card-title{font-family:var(--font-display);font-size:28px;font-weight:300;margin-bottom:6px}
.return-card-sub{font-size:12px;letter-spacing:1px;text-transform:uppercase;color:rgba(245,240,232,0.4);margin-bottom:20px}
.return-detail{font-size:13px;color:rgba(245,240,232,0.65);line-height:1.7;font-weight:300}
.return-highlight{display:inline-block;padding:2px 8px;background:rgba(184,137,42,0.2);color:var(--gold2);border-radius:4px;font-size:12px;margin-top:10px}

/* TIPS */
.tip-blocks{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:48px 0}
.tip-block{background:white;border:1px solid var(--border);border-radius:10px;padding:20px 22px}
.tip-block-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.tip-block-label::before{content:'';display:block;width:16px;height:1px;background:var(--gold)}
.tip-block ul{list-style:none;display:flex;flex-direction:column;gap:7px}
.tip-block li{font-size:12.5px;color:var(--ink2);line-height:1.5;padding-left:14px;position:relative}
.tip-block li::before{content:'—';position:absolute;left:0;color:var(--muted2)}

/* IST SPECIFICS */
.ist-banner{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;padding:40px 0 28px;border-bottom:1px solid var(--border2);margin-bottom:32px;position:relative}
.ist-briefing{background:rgba(26,92,122,0.06);border:1px solid rgba(26,92,122,0.2);border-radius:10px;padding:14px 18px;margin-bottom:24px;font-size:13px;color:var(--ink2);line-height:1.6}

footer{text-align:center;padding:40px 32px 60px;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);border-top:1px solid var(--border)}
footer span{color:var(--gold)}

@media(max-width:680px){
  .hero{padding:0 24px 64px}
  .section{padding:60px 20px}
  .hero-title{font-size:48px}
  .city-title{font-size:36px}
  .tip-blocks{grid-template-columns:1fr}
  .day-slots{padding-left:20px}
  #nav{padding:0 16px}
}
@media print{
  #nav{display:none}
  .day-body{grid-template-rows:1fr!important}
  body{background:white}
}
</style>
</head>
