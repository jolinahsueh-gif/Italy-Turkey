function buildDays(containerId, days, colorVar) {
  const c = document.getElementById(containerId);
  days.forEach((d, i) => {
    const el = document.createElement('div');
    el.className = 'day-item';
    el.style.setProperty('--city-color', `var(${colorVar})`);
    el.innerHTML = `
      <div class="day-trigger" onclick="toggle(this.parentElement)">
        <div class="day-num-badge">${i+1}</div>
        <div class="day-trigger-text">
          <div class="day-trigger-date">${d.date}</div>
          <div class="day-trigger-title">${d.title}</div>
        </div>
        <div class="day-arrow"><svg viewBox="0 0 12 8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l5 5 5-5"/></svg></div>
      </div>
      <div class="day-body"><div class="day-body-inner"><div class="day-slots">
        ${d.slots.map(s => `
          <div class="slot">
            <div class="slot-time">${s.time}</div>
            <div class="slot-main">
              <div class="slot-name">${s.name}</div>
              <div class="slot-note">${s.note}</div>
              <div class="slot-tags">
                ${s.tip  ? `<span class="tag tag-tip">${s.tip}</span>` : ''}
                ${s.food ? `<span class="tag tag-food">${s.food}</span>` : ''}
              </div>
            </div>
          </div>`).join('')}
      </div></div></div>`;
    c.appendChild(el);
  });
}

function toggle(el) { el.classList.toggle('open'); }

buildDays('rome-days', ROME_DAYS, '--rome');
buildDays('sicily-days', SICILY_DAYS, '--sicily');
buildDays('istanbul-days', ISTANBUL_DAYS, '--istanbul');

document.querySelector('#rome-days .day-item').classList.add('open');
document.querySelector('#sicily-days .day-item').classList.add('open');
document.querySelector('#istanbul-days .day-item').classList.add('open');

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.day-item').forEach((el, i) => {
  el.style.transitionDelay = `${(i % 4) * 60}ms`;
  obs.observe(el);
});

const sections = ['hero','rome','sicily','istanbul','tips'];
const steps = document.querySelectorAll('.nav-step');
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', scrollY > 20);
  let cur = 0;
  sections.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el && scrollY >= el.offsetTop - 100) cur = i;
  });
  steps.forEach((s, i) => s.classList.toggle('active', i === cur));
}, { passive: true });

function goTo(id) {
  const el = document.getElementById(id);
  if (el) window.scrollTo({ top: el.offsetTop - 52, behavior: 'smooth' });
}
</script>
